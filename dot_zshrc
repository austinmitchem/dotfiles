# Uncomment this and last line to profile zsh
# zmodload zsh/zprof

# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# zsh-nvm plugin configurations https://github.com/lukechilds/zsh-nvm
export NVM_LAZY_LOAD=true
export NVM_AUTO_USE=true
export NVM_COMPLETION=true
export NVM_LAZY_LOAD_EXTRA_COMMANDS=('make' 'code')

# Oh My Zsh configurations
export ZSH="$HOME/.oh-my-zsh"
DISABLE_AUTO_UPDATE="true" # keeps omz source directory up to date with chemzmoi source state
ZSH_THEME="powerlevel10k/powerlevel10k"
# zsh-autocomplete must be after fast-syntax-highlighting
plugins=(zsh-autosuggestions fast-syntax-highlighting zsh-autocomplete zsh-nvm dotenv colored-man-pages safe-paste)
source $ZSH/oh-my-zsh.sh

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# Source aliases
[[ -f ~/.aliases ]] && source ~/.aliases

# Setup Homebrew
if [[ -f /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Set default editor
if command -v code &>/dev/null; then
    export EDITOR="code --wait"
fi

# zsh-autocomplete configurations
zstyle ':autocomplete:*' delay 1
zstyle ':autocomplete:*' min-input 3

# History configurations
setopt HIST_EXPIRE_DUPS_FIRST # Expire duplicate entries first when trimming history.
setopt HIST_IGNORE_ALL_DUPS # Delete old recorded entry if new entry is a duplicate.
setopt HIST_FIND_NO_DUPS  # Do not display a line previously found.
setopt HIST_IGNORE_SPACE # Don't record an entry starting with a space.
setopt HIST_REDUCE_BLANKS # Remove superfluous blanks before recording entry.
unsetopt SHARE_HISTORY # Don't share history between open terminal sessions.

# Disable match_prev_cmd since it doesn't work with history configurations that alter history.
ZSH_AUTOSUGGEST_STRATEGY=(history completion)

# Source local configurations
[[ -f ~/.secrets.local ]] && source ~/.secrets.local
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

