# Uncomment this and last line to profile zsh
# zmodload zsh/zprof

# Homebrew (must be early so PATH includes /opt/homebrew/bin for all tools below)
if [[ -f /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Zinit
ZINIT_HOME="$HOME/.local/share/zinit/zinit.git"
if [[ ! -f "$ZINIT_HOME/zinit.zsh" ]]; then
    print -P "%F{33}Installing Zinit...%f"
    command mkdir -p "$HOME/.local/share/zinit" && command chmod g-rwX "$HOME/.local/share/zinit"
    command git clone https://github.com/zdharma-continuum/zinit "$ZINIT_HOME"
fi
source "$ZINIT_HOME/zinit.zsh"
autoload -Uz _zinit
(( ${+_comps} )) && _comps[zinit]=_zinit

# Prompt: Starship
eval "$(starship init zsh)"
export STARSHIP_LOG=error

# Plugins

# zsh-autocomplete must load synchronously (before async plugins)
zstyle ':autocomplete:*' delay 1
zstyle ':autocomplete:*' min-input 3
zinit light marlonrichert/zsh-autocomplete

# Async plugins (loaded after first prompt, no startup cost)
zinit ice wait lucid
zinit light zsh-users/zsh-autosuggestions

zinit ice wait lucid
zinit light zdharma-continuum/fast-syntax-highlighting

# OMZ utility plugins via snippets
zinit snippet OMZ::plugins/dotenv/dotenv.plugin.zsh
zinit snippet OMZ::plugins/colored-man-pages/colored-man-pages.plugin.zsh
zinit snippet OMZ::plugins/safe-paste/safe-paste.plugin.zsh

# Completion
autoload -Uz compinit
compinit -C

# Compile .zshrc for faster sourcing on subsequent loads
if [[ ! -f ~/.zshrc.zwc || ~/.zshrc -nt ~/.zshrc.zwc ]]; then
    zcompile ~/.zshrc
fi

# Source aliases
[[ -f ~/.aliases ]] && source ~/.aliases

# fnm (Node version manager)
if command -v fnm &>/dev/null; then
    eval "$(fnm env --use-on-cd --corepack-enabled --version-file-strategy=recursive --shell zsh)"
fi

# Default editor
if command -v code &>/dev/null; then
    export EDITOR="code --wait"
fi

# History
HISTSIZE=2000
SAVEHIST=2000
setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS
unsetopt SHARE_HISTORY

# zsh-autosuggestions
# Disable match_prev_cmd since it doesn't work with history configurations that alter history.
ZSH_AUTOSUGGEST_STRATEGY=(history completion)

# Local configurations
[[ -f ~/.secrets.local ]] && source ~/.secrets.local
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

