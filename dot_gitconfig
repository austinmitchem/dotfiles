# https://git-scm.com/docs/git-config

[alias]
	st = status

	# View abbreviated SHA, description, and history graph of the latest 20 commits
	l = log --pretty=oneline -n 20 --graph --abbrev-commit

	# Cleanup repository and switch to main branch
	fresh = !git stash && git switch main && git pull origin main

	# Show verbose output about tags, branches or remotes
	tags = tag -l
	branches = branch --all
	remotes = remote --verbose

	# List aliases
	alias = config --get-regexp alias

	# Amend the currently staged files to the latest commit
	amend = commit --amend --reuse-message=HEAD

	# Interactive rebase with the given number of latest commits. (e.g. `git rb 3`)
	rb = "!r() { git rebase -i HEAD~$1; }; r"

	# Show local branches that no longer exist on remote.
	gone = "!git for-each-ref --format='%(refname:short) %(upstream:track)' refs/heads/ | awk '$2 == \"[gone]\" {print $1}'"

	# Remove local branches that no longer exist on remote.
	rm-gone = "!git for-each-ref --format='%(refname:short) %(upstream:track)' refs/heads/ | awk '$2 == \"[gone]\" {print $1}' | xargs git branch -d"

	# Force removes local branches that no longer exist on remote. (Force is necessary when using fast-forward only merges).
	rmf-gone = "!git for-each-ref --format='%(refname:short) %(upstream:track)' refs/heads/ | awk '$2 == \"[gone]\" {print $1}' | xargs git branch -D"

	# Remove all local branches.
	rm-all = "!git for-each-ref --format '%(refname:short)' refs/heads | grep -v \"master\\|main\" | xargs git branch -d"

	# Force removes all local branches. (Force is necessary when using fast-forward only merges).
	rmf-all = "!git for-each-ref --format '%(refname:short)' refs/heads | grep -v \"master\\|main\" | xargs git branch -D"

	# List contributors with number of commits.
	contrib = shortlog --summary --numbered

	# Show the user email for the current repository.
	whoami = config user.email

	# Diff the current working tree against main.
	df = diff origin/main...HEAD

[core]
	excludesfile = ~/.gitignore
	editor = code --wait --new-window

[checkout]
	defaultRemote = origin

[credential]
	helper = osxkeychain

[diff]
	tool = vscode

[difftool "vscode"]
	cmd = code --wait --diff --new-window $LOCAL $REMOTE

[fetch]
	prune = true

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[include]
	path = ~/.gitconfig.local

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true
	default = simple
